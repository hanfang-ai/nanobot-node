{
  "name": "nanobot-node",
  "version": "0.1.0",
  "description": "Node.js implementation of nanobot, 100% compatible with the original Python version",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nanobot": "./bin/nanobot.js"
  },
  "scripts": {
    "build": "tsc && npm run build:web",
    "build:ts": "tsc",
    "build:web": "cd web && pnpm install && pnpm build",
    "start": "node dist/index.js",
    "start:web": "node dist/server/index.js",
    "dev": "ts-node src/index.ts",
    "dev:web": "cd web && pnpm dev",
    "cli": "node dist/cli/commands.js",
    "test": "jest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "ai",
    "agent",
    "chatbot",
    "nanobot",
    "openclaw"
  ],
  "author": "nanobot contributors",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "commander": "^12.0.0",
    "cors": "^2.8.6",
    "duck-duck-scrape": "^2.2.5",
    "express": "^4.22.1",
    "inquirer": "^9.2.0",
    "js-yaml": "^4.1.0",
    "lowdb": "^7.0.0",
    "mime-types": "^2.1.35",
    "node-cron": "^3.0.3",
    "openai": "^4.0.0",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.0",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.0",
    "@types/js-yaml": "^4.0.9",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}

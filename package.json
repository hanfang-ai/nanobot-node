{
  "name": "nanobot-node",
  "version": "0.1.0",
  "description": "Node.js implementation of nanobot, 100% compatible with the original Python version",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nanobot": "./bin/nanobot.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": ["ai", "agent", "chatbot", "nanobot", "openclaw"],
  "author": "nanobot contributors",
  "license": "MIT",
  "dependencies": {
    "@langchain/core": "^0.2.0",
    "litellm": "^1.82.0",
    "ws": "^8.16.0",
    "axios": "^1.6.0",
    "pino": "^8.19.0",
    "pino-pretty": "^10.3.0",
    "commander": "^12.0.0",
    "inquirer": "^9.2.0",
    "node-cron": "^3.0.3",
    "lowdb": "^7.0.0",
    "zod": "^3.22.0",
    "uuid": "^9.0.1",
    "mime-types": "^2.1.35",
    "cheerio": "^1.0.0-rc.12",
    "duckduckgo-search": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^9.0.7",
    "@types/mime-types": "^2.1.4",
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  }
}
